pin_code = 250 # можно поставить любое другое число
guess = 0
popitka = 500  # также можно поставить любое другое число

print("Начинаю взлом пин-кода...")

while guess != pin_code and popitka > 0:
    print(f"Пробую код: {guess}. Осталось попыток: {popitka}")
    guess += 1
    popitka -= 1

if guess == pin_code:
    print(f"--- Пин-код найден! Это: {guess} ---")
else:
    print("--- Взлом провален: закончились попытки! ---")
