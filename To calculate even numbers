n = int(input(f"Введите число до которого надо найти четное: "))
i = 1

while i <= n:   # Создания самого цикла
    if i > n:   # Проверка не выходит ли за пределы n
        break
    else:
        if i % 2 == 0: # Проверка на четность
            print(i)
        else:
            pass # Для завершения

    i += 1
