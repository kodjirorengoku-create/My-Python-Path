# Пример вычисление максимального числа в списке

print("Составьте список чисел. ")   # Поставленная задача

n1 = int(input(": "))       #  Переменные содержащие числа для списка
n2 = int(input(": "))
n3 = int(input(": "))
n4 = int(input(": "))
n5 = int(input(": "))

print("Максимальное число: ")
print(max(n1, n2, n3, n4, n5), sep=" ")  #  Вывод максимального числа из списка

print("Минимальное число: ")
print(min(n1, n2, n3, n4, n5), sep=" ")  #  Вывод минимального числа из списка
