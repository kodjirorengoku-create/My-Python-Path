# Калькулятор с функциями +, -, /, *.

n1 = int(input("Введите первое число: "))
n2 = int(input("Введите второе число: "))

print(f"\nФункции калькулятора.\n \n1: +\n \n2: -\n \n3: *\n \n4: /\n") # Надпись для ознакомления услуг калькулятора.

x = int(input("Введите номер функции которую хотите исполнить: "))      # Переменная отвечающая за номер какой-либо услуги.
if x == 1:
    print(n1 + n2)
elif x == 2:
    print(n1 - n2)
elif x == 3:
    print(n1 * n2)
elif x == 4:
    print(n1 / n2)
