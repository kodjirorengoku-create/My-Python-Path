import socket

target = input("IP или сайт: ")  # Твой локальный адрес
ports = [21,22,23,80,443,445,3306,8080]  # Порт для проверки (например, веб-сервер)

print(f"Сканирую {target}...\n")

for port in ports:
    sock = socket.socket()
    sock.settimeout(2)  # Ждем ответ не больше 2 секунд
    if sock.connect_ex((target, port)) == 0:
        print(f"[+] Порт {port} — ОТКРЫТ")
    sock.close()

print("Готово!")
