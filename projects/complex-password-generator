import random

# Символы, из которых будет состоять пароль
small = "abcdefghijklmnopqrstuvwxyz"
big = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
number = "0123456789"
hieroglyph = "!@#$%^&*()_+-="

# Собираем всё вместе
all_simple = small + big + number + hieroglyph

print("=== Простой генератор паролей ===\n")

# Спрашиваем длину пароля
len_pass = int(input("Какой длины сделать пароль? (рекомендую 12-16): "))

# Генерируем пароль
password = ""
for i in range(len_pass):
    password += random.choice(all_simple)

print("\nТвой пароль:")
print(password)
