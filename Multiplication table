# Что-то типа таблицы умножения.

n = int(input("Введите число: "))  # Переменная в которую вводишь число

print(f"\nТаблица умножения {n}:\n") # для красоты

for i in range(1, 11):          # Радиус умножения от 1 до 10
    print(n, "x", i, "=", n * i) # Вывод всех исполненных действий и как это будет выглядеть
