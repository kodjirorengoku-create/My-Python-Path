import time

password = "5641"
user_input = ""
attemps = 3

while attemps > 0:
    user_input = input(f"Enter your password (Attempts left: {attemps}): ")
    if user_input == password:
        print("Access allowed, safe open", sep=" ")
        break
    else:
        attemps -= 1
        time.sleep(0)
        if attemps > 0:
            print(f"Access denied. Try again", sep=" ")
        else:
            print(f"Access denied. System locked! Colling police...", sep=" ")

