# Код для входа в сейф с ограниченным кол-вом попыток

import time

password = "5641"
user_input = "" # Создаем пустую переменную, чтобы цикл начался
attemps = 3

while attemps > 0:
    # Запрашиваем пароль внутри цикла
    user_input = input(f"Enter your password. Attempts left: {attemps}: ").strip()
    if user_input == password:
        print("Access allowed, safe open")
        break
    else:
        attemps -= 1
        if attemps > 0:
            print(f"Access denied. Try again. repeat after 3 seconds")
            time.sleep(3) # Ждем только если есть смысл пробовать еще раз
        else:
            print(f"Access denied. System locked! Colling police...",)
